# ═══════════════════════════════════════════════════════════════
# IBS HI Sale Platform v4 — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════

# Environment: development | production
SALE_ENV=development

# Server Configuration
SALE_PORT=8767
API_HOST=0.0.0.0

# Database Configuration
DB_TYPE=sqlite
SALE_DB_PATH=./sale_platform.db

# PostgreSQL (if DB_TYPE=postgresql)
# PG_DSN=postgresql://user:password@localhost:5432/ibs_hi_sale
# PG_POOL_MAX=10

# API Keys — Generate with: python3 -c "import uuid; print(uuid.uuid4().hex)"
# ADMIN Tier (Full Access) — 2 keys
ADMIN_API_KEY_1=
ADMIN_API_KEY_2=

# MANAGER Tier (Write Access) — 2 keys
MANAGER_API_KEY_1=
MANAGER_API_KEY_2=

# VIEWER Tier (Read-Only) — 2 keys
VIEWER_API_KEY_1=
VIEWER_API_KEY_2=

# CORS — comma-separated origins for production
# Default "*" allows all origins (dev only)
# CORS_ORIGINS=http://localhost:3000,https://ibs.com.vn

# Layer 1 Integration (ibshi1)
IBSHI1_URL=http://localhost:3000
IBSHI1_TOKEN=

# Gmail Integration
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json
GMAIL_TOKENS_DIR=./tokens/

# Feature Flags
ENABLE_EMAIL_SYNC=true
ENABLE_PM_INTEGRATION=true
ENABLE_TASK_SCHEDULING=true

# Logging
LOG_LEVEL=INFO
